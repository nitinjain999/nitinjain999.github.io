---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import WhatIBuild from '../components/WhatIBuild.astro';
import Experience from '../components/Experience.astro';
import OpenSource from '../components/OpenSource.astro';
import Certifications from '../components/Certifications.astro';
import BlogSection from '../components/BlogSection.astro';
import HumanSide from '../components/HumanSide.astro';
import Contact from '../components/Contact.astro';
---
<Base>
  <Nav />
  <Hero />
  <div class="h-px w-full max-w-6xl mx-auto bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
  <About />
  <div class="h-px w-full max-w-6xl mx-auto bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
  <WhatIBuild />
  <div class="h-px w-full max-w-6xl mx-auto bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
  <Experience />
  <div class="h-px w-full max-w-6xl mx-auto bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
  <OpenSource />
  <div class="h-px w-full max-w-6xl mx-auto bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
  <Certifications />
  <div class="h-px w-full max-w-6xl mx-auto bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
  <BlogSection />
  <div class="h-px w-full max-w-6xl mx-auto bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
  <HumanSide />
  <div class="h-px w-full max-w-6xl mx-auto bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
  <Contact />
</Base>
