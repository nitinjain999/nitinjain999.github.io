---
const certs = [
  {
    label: 'AWS Certified Solutions Architect – Associate',
    color: 'border-orange-500/20 text-orange-300 bg-orange-500/5',
    badge: '/assets/badges/aws-sa-associate.png',
    href: 'https://www.credly.com/badges/7cf00e9d-1e4c-415a-aaf9-a46acb12e065/public_url',
  },
  {
    label: 'AWS Certified DevOps Engineer – Professional',
    color: 'border-orange-500/20 text-orange-300 bg-orange-500/5',
    badge: '/assets/badges/aws-devops-pro.png',
    href: 'https://www.credly.com/badges/8dba2993-6fd9-44e7-8397-6e8e6df86702/public_url',
  },
  {
    label: 'AWS Certified Security – Specialty',
    color: 'border-orange-500/20 text-orange-300 bg-orange-500/5',
    badge: '/assets/badges/aws-security-specialty.png',
    href: 'https://www.credly.com/badges/1f9d3678-3e1e-4603-8d50-f1e823597c1e/public_url',
  },
  {
    label: 'AWS Partner: Cloud Economics Essentials',
    color: 'border-amber-500/20 text-amber-300 bg-amber-500/5',
    badge: '/assets/badges/aws-partner-economics.png',
    href: 'https://www.credly.com/badges/ef38a92a-2a80-43b3-9324-d0c07dfaa01c/public_url',
  },
  {
    label: 'Certified Kubernetes (KCM100, Mirantis)',
    color: 'border-blue-500/20 text-blue-300 bg-blue-500/5',
    logo: 'k8s',
  },
  {
    label: 'Google Professional Cloud Architect',
    color: 'border-green-500/20 text-green-300 bg-green-500/5',
    logo: 'gcp',
  },
  {
    label: 'Implementing Azure Infrastructure, Exam 533',
    color: 'border-sky-500/20 text-sky-300 bg-sky-500/5',
    logo: 'azure',
  },
];
---

<section id="certs" class="relative py-28 px-6">
  <div class="relative max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="eyebrow mb-3 opacity-0 certs-eyebrow">Credentials</p>
      <h2 class="section-title text-white opacity-0 certs-heading">Certifications</h2>
    </div>

    <div class="flex flex-wrap justify-center gap-3">
      {certs.map((c) => {
        const pill = (
          <span class={`cert-badge opacity-0 inline-flex items-center gap-2.5 px-4 py-2.5 rounded-full border text-xs font-mono tracking-wide transition-all duration-200 ${c.color} ${c.href ? 'hover:brightness-125 hover:scale-105 cursor-pointer' : ''}`}>
            {c.badge && (
              <img src={c.badge} alt="" width="20" height="20"
                   class="rounded-sm object-contain flex-shrink-0" aria-hidden="true" />
            )}
            {c.logo === 'k8s' && (
              <svg width="18" height="18" viewBox="0 0 48 48" fill="none" aria-hidden="true" class="flex-shrink-0">
                <circle cx="24" cy="24" r="20" fill="#326CE5"/>
                <path d="M24 9l2.8 8.5h8.9l-7.2 5.2 2.8 8.5L24 26l-7.3 5.2 2.8-8.5-7.2-5.2h8.9L24 9z" fill="white"/>
                <circle cx="24" cy="24" r="3.5" fill="white"/>
              </svg>
            )}
            {c.logo === 'gcp' && (
              <svg width="18" height="18" viewBox="0 0 48 48" fill="none" aria-hidden="true" class="flex-shrink-0">
                <path d="M29.8 13.2H18.2l-11 11 11 11h11.6l11-11-11-11z" fill="#4285F4"/>
                <path d="M24 17l-7 7 7 7 7-7-7-7z" fill="white"/>
                <circle cx="24" cy="24" r="3.5" fill="#4285F4"/>
              </svg>
            )}
            {c.logo === 'azure' && (
              <svg width="18" height="18" viewBox="0 0 48 48" fill="none" aria-hidden="true" class="flex-shrink-0">
                <path d="M20.5 6.5L9 34h8.5l4.5-11 9 20H9.5l-4 7h37L20.5 6.5z" fill="#0078D4"/>
              </svg>
            )}
            {c.label}
            {c.href && (
              <svg width="9" height="9" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="opacity-40 flex-shrink-0">
                <path d="M10 1H1v10M10 1L1 10M10 1v6M10 1H4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
          </span>
        );
        return c.href
          ? <a href={c.href} target="_blank" rel="noopener noreferrer">{pill}</a>
          : pill;
      })}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | undefined;

  function init() {
    ctx?.revert();
    ctx = gsap.context(() => {
      gsap.registerPlugin(ScrollTrigger);
      const st = { trigger: '#certs', start: 'top 80%' };
      gsap.fromTo('.certs-eyebrow', { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.5, scrollTrigger: st });
      gsap.fromTo('.certs-heading', { opacity: 0, y: 25 }, { opacity: 1, y: 0, duration: 0.6, delay: 0.05, scrollTrigger: st });
      gsap.fromTo(
        gsap.utils.toArray('.cert-badge'),
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.45, stagger: (i) => i * 0.07, scrollTrigger: st }
      );
    });
  }

  document.addEventListener('astro:page-load', init);
</script>
