---
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<section id="blog" class="py-24 px-6 max-w-6xl mx-auto">
  <h2 class="blog-heading text-3xl font-bold mb-4 text-center opacity-0">Writing</h2>
  <p class="blog-sub text-white/50 text-center mb-16 opacity-0">Platform engineering, from the trenches.</p>

  <div class="grid md:grid-cols-3 gap-6 mb-10">
    {posts.map((post, i) => (
      <a href={`/blog/${post.id}`} class="blog-card glass p-6 opacity-0 flex flex-col gap-4 group">
        <div class="flex flex-wrap gap-2">
          {post.data.tags.slice(0, 2).map(tag => (
            <span class="text-xs font-mono px-2 py-0.5 bg-cyan/10 text-cyan border border-cyan/20 rounded">{tag}</span>
          ))}
        </div>
        <h3 class="font-bold text-white leading-snug group-hover:text-cyan transition-colors">{post.data.title}</h3>
        <p class="text-white/50 text-sm leading-relaxed flex-1">{post.data.description}</p>
        <div class="flex justify-between text-xs text-white/30 font-mono mt-auto">
          <span>{post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
        </div>
      </a>
    ))}
  </div>
  <div class="text-center blog-link opacity-0">
    <a href="/blog" class="text-cyan font-medium hover:underline text-sm">View all posts →</a>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function init() {
    ScrollTrigger.getAll().forEach(t => t.kill());
    gsap.registerPlugin(ScrollTrigger);
    const st = { trigger: '#blog', start: 'top 78%' };
    gsap.fromTo('.blog-heading', { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.6, scrollTrigger: st });
    gsap.fromTo('.blog-sub',     { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.5, delay: 0.1, scrollTrigger: st });
    gsap.fromTo(
      gsap.utils.toArray('.blog-card'),
      { opacity: 0, y: 30 },
      {
        opacity: 1, y: 0, duration: 0.55,
        stagger: (i) => i * 0.1,
        scrollTrigger: { trigger: '#blog', start: 'top 74%' },
      }
    );
    gsap.fromTo('.blog-link', { opacity: 0 }, { opacity: 1, duration: 0.5,
      scrollTrigger: { trigger: '#blog', start: 'top 68%' } });
  }

  document.addEventListener('astro:page-load', init);
</script>
