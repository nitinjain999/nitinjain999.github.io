---
---

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden">

  <!-- Animated mesh gradient background -->
  <div id="hero-mesh" class="absolute inset-0 z-0" aria-hidden="true">
    <div class="mesh-bg absolute inset-0"></div>
    <!-- Extra depth blobs -->
    <div class="blob-1 absolute w-[600px] h-[600px] rounded-full pointer-events-none"
         style="background:radial-gradient(circle,rgba(0,180,216,0.12) 0%,transparent 70%);top:-100px;left:-150px;"></div>
    <div class="blob-2 absolute w-[500px] h-[500px] rounded-full pointer-events-none"
         style="background:radial-gradient(circle,rgba(99,102,241,0.15) 0%,transparent 70%);bottom:-50px;right:-100px;"></div>
    <!-- Subtle grid overlay -->
    <div class="absolute inset-0 opacity-[0.03]"
         style="background-image:linear-gradient(rgba(255,255,255,0.5) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.5) 1px,transparent 1px);background-size:60px 60px;"></div>
  </div>

  <!-- Gradient fade at bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-48 z-10 bg-gradient-to-t from-background to-transparent pointer-events-none" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-20 flex flex-col items-center text-center px-6 max-w-5xl mx-auto w-full">

    <!-- Location + status row -->
    <div id="hero-meta" class="opacity-0 flex flex-wrap items-center justify-center gap-3 mb-8">
      <span class="inline-flex items-center gap-1.5 text-xs font-mono text-white/35">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M8 1C5.24 1 3 3.24 3 6c0 3.75 5 9 5 9s5-5.25 5-9c0-2.76-2.24-5-5-5zm0 6.75A1.75 1.75 0 1 1 8 4.25a1.75 1.75 0 0 1 0 3.5z" fill="currentColor"/></svg>
        Stockholm, Sweden
      </span>
      <span class="text-white/15">·</span>
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-cyan/25 bg-cyan/5 text-cyan text-xs font-mono tracking-wide">
        <span class="w-1.5 h-1.5 rounded-full bg-cyan animate-pulse inline-block"></span>
        Open for interesting projects
      </span>
      <span class="text-white/15">·</span>
      <span class="text-xs font-mono text-white/35">15+ yrs experience</span>
    </div>

    <!-- Name heading — split into character spans by GSAP -->
    <h1 id="hero-name" class="opacity-0 font-extrabold tracking-tight mb-5 leading-none"
        style="font-size:clamp(4rem,12vw,8.5rem);">
      Nitin Jain
    </h1>

    <!-- Title with gradient accent -->
    <p id="hero-title" class="opacity-0 font-light mb-3"
       style="font-size:clamp(1.25rem,2.8vw,1.75rem);">
      <span class="text-white/50">Principal</span>
      <span class="grad-text font-semibold"> Platform Engineer</span>
    </p>

    <!-- Typewriter tagline -->
    <p id="hero-tagline" class="min-h-[2.5rem] text-white/35 font-mono mb-10 max-w-2xl"
       style="font-size:clamp(0.85rem,1.4vw,1rem);"></p>

    <!-- Tech stack pills -->
    <div id="hero-stack" class="opacity-0 flex flex-wrap justify-center gap-2 mb-12">
      {['EKS', 'Terraform', 'FluxCD', 'GitHub Actions', 'Datadog', 'AWS', 'Kubernetes', 'GitOps', 'OpenShift', 'Helm', 'ArgoCD', 'Kyverno', 'KEDA', 'Linkerd', 'OPA', 'Dynatrace', 'Python', 'Bash'].map(t => (
        <span class="font-mono px-3 py-1 rounded-full border border-cyan/20 text-cyan/70 bg-cyan/[0.04] hover:border-cyan/50 hover:text-cyan hover:bg-cyan/[0.08] transition-colors duration-200"
              style="font-size:clamp(0.7rem,1vw,0.8rem);">
          {t}
        </span>
      ))}
    </div>

    <!-- CTAs — primary + one secondary only -->
    <div id="hero-ctas" class="opacity-0 flex flex-wrap gap-3 justify-center">
      <a href="#contact"
         onclick="document.getElementById('contact')?.scrollIntoView({behavior:'smooth'}); return false;"
         class="rounded-xl font-semibold text-black transition-all duration-200 hover:scale-105 active:scale-95"
         style="padding:0.8em 2em;font-size:clamp(0.85rem,1.2vw,1rem);background:linear-gradient(135deg,#00B4D8,#6366f1);">
        Let's Connect
      </a>
      <a href="#experience"
         class="rounded-xl border border-white/20 text-white/90 font-medium hover:border-cyan/40 hover:text-white transition-all duration-200"
         style="padding:0.8em 2em;font-size:clamp(0.85rem,1.2vw,1rem);">
        View Experience
      </a>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div id="hero-scroll" class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 opacity-0">
    <span class="text-[9px] font-mono tracking-[0.3em] text-white/20 uppercase">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-cyan/60 to-transparent scroll-line"></div>
  </div>

</section>

<style>
  .mesh-bg {
    background:
      radial-gradient(ellipse 80% 60% at 15% 40%, rgba(0,180,216,0.18) 0%, transparent 65%),
      radial-gradient(ellipse 70% 60% at 85% 60%, rgba(99,102,241,0.22) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 50% 90%, rgba(0,180,216,0.08) 0%, transparent 60%);
    animation: meshShift 14s ease-in-out infinite alternate;
    will-change: transform;
  }

  @keyframes meshShift {
    0%   { transform: translate(0px,   0px)   scale(1);    }
    33%  { transform: translate(25px,  -20px) scale(1.05); }
    66%  { transform: translate(-20px,  25px) scale(0.96); }
    100% { transform: translate(12px,   12px) scale(1.03); }
  }

  .scroll-line {
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1);   }
    50%       { opacity: 1;   transform: scaleY(0.7); }
  }

  #hero-name .char-wrap {
    display: inline-block;
    overflow: hidden;
    line-height: 1.05;
    vertical-align: bottom;
  }
  #hero-name .char {
    display: inline-block;
    transform: translateY(105%);
    opacity: 0;
  }
  #hero-name .char-space {
    display: inline-block;
    width: 0.28em;
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', init);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  function init() {
    const nameEl = document.getElementById('hero-name');
    if (!nameEl || nameEl.dataset.heroInit === '1') return;
    nameEl.dataset.heroInit = '1';

    // Split into char spans — space gets fixed-width span so "Nitin Jain" stays two words.
    // Trim first to avoid leading/trailing whitespace creating phantom space spans.
    // Width is set inline because Astro scoped styles don't apply to dynamically created elements.
    const originalText = (nameEl.textContent ?? '').trim();
    nameEl.innerHTML = '';
    nameEl.style.opacity = '1';

    for (const ch of originalText) {
      if (ch === ' ') {
        const sp = document.createElement('span');
        sp.className = 'char-space';
        sp.setAttribute('aria-hidden', 'true');
        sp.style.display = 'inline-block';
        sp.style.width = '0.35em';
        nameEl.appendChild(sp);
      } else {
        const wrap = document.createElement('span');
        wrap.className = 'char-wrap';
        const inner = document.createElement('span');
        inner.className = 'char';
        inner.textContent = ch;
        wrap.appendChild(inner);
        nameEl.appendChild(wrap);
      }
    }

    const chars = nameEl.querySelectorAll<HTMLElement>('.char');

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Meta row
    tl.to('#hero-meta',   { opacity: 1, y: 0, duration: 0.6 }, 0.2);
    // Characters
    tl.to(chars,          { y: 0, opacity: 1, duration: 0.65, stagger: 0.04 }, 0.35);
    // Title
    tl.fromTo('#hero-title',   { y: 20, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6 }, 0.7);
    // Stack pills
    tl.to('#hero-stack',  { opacity: 1, duration: 0.5 }, 1.0);
    // CTAs
    tl.to('#hero-ctas',   { opacity: 1, duration: 0.5 }, 1.15);
    // Scroll
    tl.to('#hero-scroll', { opacity: 1, duration: 0.5 }, 1.4);

    // Typewriter
    const lines = [
      'I build the cloud platform hundreds of engineers ship on every day.',
      "If it's not in Git, it doesn't exist.",
      "I don't follow platform best practices — I write them.",
    ];
    const tagline = document.getElementById('hero-tagline');
    if (tagline) {
      let lineIdx = 0, charIdx = 0;
      let typeTimer: ReturnType<typeof setTimeout>;

      function typeChar() {
        if (!tagline) return;
        if (charIdx <= lines[lineIdx].length) {
          tagline.textContent = lines[lineIdx].slice(0, charIdx++);
          typeTimer = setTimeout(typeChar, 48);
        } else {
          typeTimer = setTimeout(() => {
            gsap.to(tagline, { opacity: 0, duration: 0.4, onComplete: () => {
              tagline.textContent = '';
              tagline.style.opacity = '1';
              lineIdx = (lineIdx + 1) % lines.length;
              charIdx = 0;
              typeTimer = setTimeout(typeChar, 200);
            }});
          }, 3000);
        }
      }
      typeTimer = setTimeout(typeChar, 1400);
    }

    // Gyroscope parallax (mobile)
    const mesh = document.getElementById('hero-mesh');
    if (mesh && window.DeviceOrientationEvent) {
      if (/Mobi|Android|iPhone|iPad/i.test(navigator.userAgent)) {
        window.addEventListener('deviceorientation', (e: DeviceOrientationEvent) => {
          gsap.to(mesh, { x: (e.gamma ?? 0) * 1.5, y: (e.beta ?? 0) * 1.5, duration: 0.8, ease: 'power1.out' });
        }, { passive: true });
      }
    }
  }
</script>
