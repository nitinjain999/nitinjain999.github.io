<section id="contact" class="py-24 px-6 max-w-4xl mx-auto">
  <div class="glass p-10 md:p-14 text-center contact-card opacity-0">
    <h2 class="text-3xl md:text-4xl font-extrabold mb-4">Have a platform challenge?</h2>
    <p class="text-white/60 leading-relaxed max-w-xl mx-auto mb-8 text-lg">
      I take select freelance engagements. EKS, Terraform, GitOps, cloud architecture,
      policy as code — if it's complex, I've probably already solved it.
    </p>
    <a
      href="mailto:nitin.solna@gmail.com"
      class="inline-flex items-center gap-2 px-8 py-3 bg-cyan text-black font-semibold rounded-lg hover:bg-cyan/90 active:scale-95 transition-all text-lg"
    >
      Get in touch →
    </a>
  </div>

  <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4 text-white/40 text-sm font-mono">
    <div class="flex flex-wrap gap-x-4 gap-y-2 justify-center md:justify-start items-center">
      <span>📍 Stockholm, Sweden</span>
      <a href="mailto:nitin.solna@gmail.com" class="hover:text-cyan transition-colors">nitin.solna@gmail.com</a>
      <a href="tel:+46730787990" class="hover:text-cyan transition-colors">+46 730 787 990</a>
      <a href="https://github.com/nitinjain999" target="_blank" rel="noopener" class="hover:text-cyan transition-colors">GitHub</a>
      <a href="https://www.linkedin.com/in/nitinjain999/" target="_blank" rel="noopener" class="hover:text-cyan transition-colors">LinkedIn</a>
    </div>
    <span class="flex-shrink-0">© 2026 Nitin Jain</span>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | undefined;

  function init() {
    ctx?.revert();
    ctx = gsap.context(() => {
      gsap.registerPlugin(ScrollTrigger);
      gsap.fromTo('.contact-card',
        { opacity: 0, y: 40 },
        { opacity: 1, y: 0, duration: 0.7,
          scrollTrigger: { trigger: '#contact', start: 'top 80%' } });
    });
  }

  document.addEventListener('astro:page-load', init);
</script>
