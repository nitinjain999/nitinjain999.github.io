---
<section id="experience" class="py-24 px-6 max-w-6xl mx-auto">
  <div class="text-center mb-16">
    <p class="eyebrow mb-3 opacity-0 exp-eyebrow">Career</p>
    <h2 class="section-title text-white opacity-0 exp-heading">Experience</h2>
  </div>
  <div class="exp-body opacity-0">
    <ExperienceTabs {roles} client:visible />
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | undefined;

  function init() {
    ctx?.revert();
    ctx = gsap.context(() => {
      gsap.registerPlugin(ScrollTrigger);
      const st = { trigger: '#experience', start: 'top 75%' };
      gsap.fromTo('.exp-eyebrow', { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.5, scrollTrigger: { ...st, start: 'top 80%' } });
      gsap.fromTo('.exp-heading', { opacity: 0, y: 25 }, { opacity: 1, y: 0, duration: 0.6, delay: 0.05, scrollTrigger: { ...st, start: 'top 80%' } });
      gsap.fromTo('.exp-body',    { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.7, scrollTrigger: st });
    });
  }

  document.addEventListener('astro:page-load', init);
</script>
