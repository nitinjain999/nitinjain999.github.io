---
<section id="experience" class="py-24 px-6 max-w-6xl mx-auto">
  <h2 class="exp-heading text-3xl font-bold mb-16 text-center opacity-0">Experience</h2>
  <div class="exp-body opacity-0">
    <ExperienceTabs {roles} client:visible />
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function init() {
    ScrollTrigger.getAll().forEach(t => t.kill());
    gsap.registerPlugin(ScrollTrigger);
    const st = { trigger: '#experience', start: 'top 75%' };
    gsap.fromTo('.exp-heading', { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.6, scrollTrigger: { ...st, start: 'top 80%' } });
    gsap.fromTo('.exp-body',    { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.7, scrollTrigger: st });
  }

  document.addEventListener('astro:page-load', init);
</script>
