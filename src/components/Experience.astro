  {
    title: 'Team Lead, IPTV Operations',
    company: 'Alcatel-Lucent Managed Services',
    period: '2010 – 2011',
    location: '—',
    logo: 'alcatel',
    bullets: ['Led IPTV operations and managed service delivery for enterprise clients.'],
  },
  {
    title: 'Engineer, IPTV Services',
