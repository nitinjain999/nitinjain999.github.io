---
const tags = ['Kubernetes', 'Terraform', 'GitOps', 'KEDA', 'Linkerd', 'OPA', 'Kyverno'];
---
<section id="opensource" class="py-24 px-6 max-w-6xl mx-auto">
  <h2 class="os-heading text-3xl font-bold mb-16 text-center opacity-0">Open Source</h2>

  <div class="glass p-8 md:p-10 os-card opacity-0">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">⚡</span>
          <h3 class="text-2xl font-bold text-white">platform-skills</h3>
        </div>
        <p class="text-white/60 leading-relaxed mb-6">
          A Claude Code skill that encodes real-world platform patterns across Kubernetes, Terraform,
          GitOps, KEDA, Linkerd, OPA and Kyverno — drawn from production incidents, not documentation.
          Most AI assistants give advice that would get you paged at 3am. This one won't.
        </p>
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.map(tag => (
            <span class="px-3 py-1 text-xs font-mono bg-cyan/10 text-cyan border border-cyan/20 rounded-full">
              {tag}
            </span>
          ))}
        </div>
        <a
          href="https://github.com/nitinjain999/platform-skills"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-2.5 bg-cyan text-black font-semibold rounded-lg hover:bg-cyan/90 active:scale-95 transition-all text-sm"
        >
          View on GitHub →
        </a>
      </div>
      <div class="rounded-xl overflow-hidden border border-white/10 bg-black/20">
        <img
          src="/assets/keda-architecture.svg"
          alt="KEDA architecture diagram"
          class="w-full h-auto"
          loading="lazy"
          width="600"
          height="400"
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | undefined;

  function init() {
    ctx?.revert();
    ctx = gsap.context(() => {
      gsap.registerPlugin(ScrollTrigger);
      gsap.fromTo('.os-heading',
        { opacity: 0, y: 30 },
        { opacity: 1, y: 0, duration: 0.6,
          scrollTrigger: { trigger: '#opensource', start: 'top 80%' } });
      gsap.fromTo('.os-card',
        { opacity: 0, y: 40 },
        { opacity: 1, y: 0, duration: 0.7,
          scrollTrigger: { trigger: '#opensource', start: 'top 75%' } });
    });
  }

  document.addEventListener('astro:page-load', init);
</script>
